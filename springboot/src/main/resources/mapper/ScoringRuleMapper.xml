<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.ScoringRuleMapper">

    <select id="selectAll" resultType="com.example.entity.ScoringRule">
        select * from scoring_rule
        <where>
            <if test="interviewType != null and interviewType != ''">and interview_type = #{interviewType}</if>
            <if test="dimension != null and dimension != ''">and dimension like concat('%', #{dimension}, '%')</if>
            <if test="enabled != null">and enabled = #{enabled}</if>
        </where>
        order by interview_type asc, weight desc, id asc
    </select>

    <insert id="insert" parameterType="com.example.entity.ScoringRule" useGeneratedKeys="true" keyProperty="id">
        insert into scoring_rule
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="interviewType != null">interview_type,</if>
            <if test="dimension != null">dimension,</if>
            <if test="criteria != null">criteria,</if>
            <if test="weight != null">weight,</if>
            <if test="enabled != null">enabled,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="interviewType != null">#{interviewType},</if>
            <if test="dimension != null">#{dimension},</if>
            <if test="criteria != null">#{criteria},</if>
            <if test="weight != null">#{weight},</if>
            <if test="enabled != null">#{enabled},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.example.entity.ScoringRule">
        update scoring_rule
        <set>
            <if test="interviewType != null">interview_type = #{interviewType},</if>
            <if test="dimension != null">dimension = #{dimension},</if>
            <if test="criteria != null">criteria = #{criteria},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="enabled != null">enabled = #{enabled},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from scoring_rule where id = #{id}
    </delete>
</mapper>
